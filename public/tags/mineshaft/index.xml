	width=&#34;1000&#34;
	height=&#34;750&#34;
	srcset=&#34;http://localhost:1313/p/smeardon-down/10_hu_8c7ca5ef2d35bf28.jpg 480w, http://localhost:1313/p/smeardon-down/10_hu_1f18251fd885e4ec.jpg 1024w&#34;
	loading=&#34;lazy&#34;
	
