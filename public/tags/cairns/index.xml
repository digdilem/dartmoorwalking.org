	srcset=&#34;http://localhost:1313/p/bellever-woods-and-cairns/6_hu_84da7bbdc37db62d.jpg 480w, http://localhost:1313/p/bellever-woods-and-cairns/6_hu_9d3dcff9261e513b.jpg 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;Rain water running out of the peat layer in the forest into a gully&#34;
	
	
